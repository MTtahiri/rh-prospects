{
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {"source": "/sitemap.xml", "destination": "/public/sitemap.xml"},
    {"source": "/robots.txt", "destination": "/public/robots.txt"},
    {"source": "/api/(.*)", "destination": "/api/offres"}
  ],
  "redirects": [
    {
      "source": "/",
      "has": [{"type": "host", "value": "dashboard.rh-prospects.fr"}],
      "destination": "/dashboard.html",
      "permanent": false
    },
    {
      "source": "/confidentialite",
      "destination": "/politique-confidentialite",
      "permanent": true
    }
  ]
}
