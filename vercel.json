{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/offres"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "dashboard.rh-prospects.fr"
        }
      ],
      "destination": "/dashboard.html",
      "permanent": false
    }
  ]
}
